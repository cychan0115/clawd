# System Hourly Inspection Configuration
# Copy to .env and fill in your values

# HTTP Endpoints to check (comma-separated URLs)
HTTP_ENDPOINTS=http://localhost:8080/health,http://localhost:3000

# SMTP Settings for sending alert emails
SMTP_HOST=smtp.139.com
SMTP_PORT=25
SMTP_USER=13926262295@139.com
SMTP_PASS=your-smtp-password
ALERT_RECIPIENT=13926262295@139.com

# K8S Context (optional, uses current context if empty)
K8S_CONTEXT=

# Thresholds
CPU_THRESHOLD=80
MEM_THRESHOLD=80
DISK_THRESHOLD=85
LOAD_THRESHOLD=5.0
